{#
name: i3Dnet SSH Cluster
description: |
  <p>Creates a cluster on i3Dnet infrastructure using OpenNebula SSH datastore drivers.</p>
  <ul>
    <li><strong>Requirements</strong>: Supported OS and attributes are defined by the provision inputs.</li>
    <li><strong>Storage</strong>: VM images are copied to each host over SSH and stored on local disk.</li>
    <li><strong>Network</strong>: VXLAN overlay with FRR-based routing over a physical NIC on each host.
      <ul><li>Elastic IPs are <strong>NOT</strong> supported in this provider.</li></ul>
    </li>
  </ul>
#}

---
all:
  vars:
    one_version: "{{ one.version }}"
    features:
      evpn: true
    ds:
      mode: generic
      config:
        SYSTEM_DS:
          i3dnet_system_ds:
            id: "{{ one.system_ds_id }}"
            template:
              type: SYSTEM_DS
              tm_mad: ssh
              safe_dirs: "/var/tmp /tmp"
        IMAGE_DS:
          i3dnet_image_ds:
            id: "{{ one.image_ds_id }}"
            template:
              type: IMAGE_DS
              ds_mad: fs
              tm_mad: ssh
              safe_dirs: "/var/tmp /tmp"
    vn:
      private_i3dnet_network:
        managed: true
        template:
          vn_mad: vxlan
          vxlan_mode: evpn
          automatic_vlan_id: "yes"
          phydev: enp125s0
          ip_link_conf: nolearning=
          guest_mtu: 1450
          network_address: 172.17.2.0
          network_mask: 255.255.255.0
          gateway: 172.17.2.1
          dns: 1.1.1.1
          ar:
            type: ip4
            ip: 172.17.2.100
            size: 100
    allowed_ports:
      - protocol: tcp
        ports:
          - 22
          - 179
      - protocol: udp
        ports:
          - 8472

frontend:
  vars:
    repos_enabled: []
  hosts:
    f1: { ansible_user: oneadmin, ansible_become: false, ansible_host: "{{ one.frontend_ip }}" }

node:
  hosts:
    {% for node in one.nodes %}
    n{{ loop.index }}: { ansible_user: root, ansible_host: "{{ node }}" }
    {% endfor %}

router:
  hosts:
    {% if one.nodes | length > 0 %}
    n1: { ansible_user: root, ansible_host: "{{ one.nodes[0] }}" }
    {% endif %}
